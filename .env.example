NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the /admin routes to bypass RLS for CRUD writes.
SUPABASE_SERVICE_ROLE_KEY=

# Set to any string. The /admin login form accepts this value.
ADMIN_TOKEN=

# Used to build absolute URLs in Open Graph / canonical tags.
# Falls back to VERCEL_URL on Vercel, or http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=
