# =============================================================================
# Wayfind — environment template
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — public (safe to expose to the browser)
# Where to find: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# -----------------------------------------------------------------------------
# Supabase — server-only (NEVER expose to the browser)
# Used by /admin routes to bypass RLS for CRUD writes.
# Same location: Project Settings → API → `service_role` secret.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Admin login password
# Any random string. The /admin login form accepts this exact value.
# Generate one: `openssl rand -hex 24`
# -----------------------------------------------------------------------------
ADMIN_TOKEN=change-me-to-a-random-string

# -----------------------------------------------------------------------------
# Public site URL — used to build absolute URLs in Open Graph / canonical tags
# Local dev:   http://localhost:3000
# Production:  https://your-domain.com  (or your Vercel URL)
# Falls back to VERCEL_URL on Vercel, or http://localhost:3000 in dev.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
